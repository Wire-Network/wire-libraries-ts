{
  "name": "@wireio/sdk-core",
  "description": "Library for working with Wire powered blockchains.",
  "version": "1.0.21",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "types": "lib/esm/index.d.ts",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/esm/index.d.ts"
    },
    "./*": {
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js",
      "types": "./lib/esm/*.d.ts"
    }
  },
  "access": "public",
  "license": "FSL-1.1-Apache-2.0",
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "test": "jest",
    "fix:hybrid:exports": "node ../../scripts/fix-hybrid-output.mjs ."
  },
  "dependencies": {
    "@3fv/prelude-ts": "^0.8.37",
    "@noble/curves": "1.9.7",
    "@wireio/shared": "workspace:*",
    "bn.js": "^4.11.9",
    "brorand": "^1.1.0",
    "elliptic": "^6.5.4",
    "ethers": "^5.7.0",
    "hash.js": "^1.0.0",
    "js-big-decimal": "^2.0.7",
    "lodash":"^4.18.1",
    "pako": "^2.1.0",
    "tslib": "^2.1.0",
    "ts-pattern":"^5.9.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^22.15.3",
    "source-map-support": "^0.5.21",
    "typescript": "6.0.2"
  }
}
