{
  "name": "@wireio/shared-node",
  "version": "1.0.21",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "types": "lib/esm/index.d.ts",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/esm/index.d.ts"
    },
    "./*": {
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js",
      "types": "./lib/esm/*.d.ts"
    }
  },
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "fix:hybrid:package": "node ../../scripts/fix-hybrid-output.mjs .",
    "test": "jest"
  },
  "devDependencies": {
    "@types/lodash": "4.17.23",
    "@types/node": "^22.15.3",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@3fv/prelude-ts": "^0.8.37",
    "@wireio/shared": "workspace:*"
  }
}
