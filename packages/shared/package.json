{
  "name": "@wireio/shared",
  "version": "1.0.19",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "type": "module",
  "types": "lib/esm/index.d.ts",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/esm/index.d.ts"
    },
    "./*": {
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js",
      "types": "./lib/esm/*.d.ts"
    }
  },
  "access": "public",
  "scripts": {
    "build": "tsc -b tsconfig.json && node ../../scripts/fix-hybrid-output.mjs .",
    "build:dev": "tsc -b tsconfig.json -w",
    "test": "jest"
  },
  "devDependencies": {
    "@types/lodash": "4.17.23",
    "@types/node": "^22.15.3",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@aws-sdk/client-firehose": "3.972.0",
    "@aws-sdk/client-sts": "3.972.0",
    "bluebird": "3.7.2",
    "debug": "^4.3.4",
    "eventemitter3": "^5.0.4",
    "lodash": "^4.17.21",
    "@3fv/prelude-ts": "^0.8.37",
    "tracer": "^1.3.0"
  }
}
