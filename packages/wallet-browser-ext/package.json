{
  "name": "@wireio/wallet-browser-ext",
  "version": "0.1.9",
  "private": true,
  "types": "lib/esm/Types.d.ts",
  "main": "lib/cjs/Types.js",
  "module": "lib/esm/Types.js",
  "exports": {
    ".": {
      "import": "./lib/esm/Types.js",
      "require": "./lib/cjs/Types.js",
      "types": "./lib/esm/Types.d.ts"
    },
    "./*": {
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js",
      "types": "./lib/esm/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json && node ../../scripts/fix-hybrid-output.mjs .",
    "build:dev": "tsc -b tsconfig.json -w",
    "bundle": "webpack --mode production",
    "bundle:dev": "webpack --mode development --watch",
    "clean": "rm -rf dist lib",
    "test": "jest"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "@wireio/sdk-core": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "tslib": "^2.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "6.0.2",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  }
}
