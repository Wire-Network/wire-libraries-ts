{
  "name": "@wireio/wallet-ext-sdk",
  "description": "Client SDK for the Wire Wallet browser extension",
  "version": "0.1.9",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "types": "lib/esm/index.d.ts",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/esm/index.d.ts"
    },
    "./*": {
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js",
      "types": "./lib/esm/*.d.ts"
    }
  },
  "license": "FSL-1.1-Apache-2.0",
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "build": "pnpm run compile && node ../../scripts/fix-hybrid-output.mjs .",
    "test": "pnpm run build && jest"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "@wireio/sdk-core": "workspace:*"
  }
}
